from collections import deque

class Solution:
    def cntOnes(self, grid: list[list[int]]) -> int:
        n, m = len(grid), len(grid[0])
        q = deque()
        
        for i in range(n):
            for j in (0, m - 1):
                if grid[i][j] == 1:
                    q.append((i, j))
                    grid[i][j] = 0
                    
        for i in (0, n - 1):
            for j in range(1, m - 1):
                if grid[i][j] == 1:
                    q.append((i, j))
                    grid[i][j] = 0
                    
        while q:
            r, c = q.popleft()
            for dr, dc in ((-1, 0), (1, 0), (0, -1), (0, 1)):
                nr, nc = r + dr, c + dc
                if 0 <= nr < n and 0 <= nc < m and grid[nr][nc] == 1:
                    grid[nr][nc] = 0
                    q.append((nr, nc))
                    
        return sum(grid[i][j] for i in range(n) for j in range(m))
